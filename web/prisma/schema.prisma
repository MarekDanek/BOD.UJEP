generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}
model Vrstva {
  id        String   @id @default(cuid())
  nazev     String
  popis     String?
  barva     String?  // Zatím volitelné
  ikona     String?  // Zatím volitelné

  mise      Mise[]

  vytvoreno DateTime @default(now())
  upraveno  DateTime @updatedAt
}

model Mise {
  id           String   @id @default(cuid())
  vrstvaId     String
  vrstva       Vrstva   @relation(fields: [vrstvaId], references: [id], onDelete: Cascade)

  nazev        String
  podnadpis    String
  textCast1    String
  obrazekCesta String
  textCast2    String
  pocetBodu    String
  vzdalenost   String
  obtiznost    String
  cas          String
  bonusy       String
  typ          String

  bodyMise     BodMise[]

  vytvoreno    DateTime  @default(now())
  upraveno     DateTime  @updatedAt
}

model BodMise {
  id             String   @id @default(cuid())
  miseId         String
  mise           Mise     @relation(fields: [miseId], references: [id], onDelete: Cascade)

  poradi         Int      // Určuje pořadí bodu v trase (1, 2, 3...)
  nazevBodu      String
  podnadpis      String
  textCast1      String
  obrazekCesta   String
  textCast2      String
  lat            Float
  lon            Float
  bonusAudioPath String?

  bonusoveStranky BonusovaStranka[]

  @@unique([miseId, poradi])
}

model BonusovaStranka {
  id             String   @id @default(cuid())
  bodMiseId      String
  bodMise        BodMise  @relation(fields: [bodMiseId], references: [id], onDelete: Cascade)

  poradi         Int      // Určuje pořadí stránky v bonusovém popupu
  obrazek        String?
  podnadpis      String?
  text           String
  malyText       String?
  zaoblitObrazek Boolean  @default(false)
}