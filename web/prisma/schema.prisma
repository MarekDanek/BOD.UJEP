generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Trasa {
  id          Int      @id @default(autoincrement())
  nazev       String
  popis       String?
  delkaKm     Float?
  bodyTrasy   String
  vytvoreno   DateTime @default(now())
}