generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Vrstva {
  id        String   @id @default(cuid())
  nazev     String
  popis     String?
  barva     String?  @default("#FAED41") // Hlavní barva pro přebarvení UI v aplikaci

  mise      Mise[]

  vytvoreno DateTime @default(now())
  upraveno  DateTime @updatedAt
}

model Mise {
  id            String   @id @default(cuid())
  vrstvaId      String
  vrstva        Vrstva   @relation(fields: [vrstvaId], references: [id], onDelete: Cascade)

  nazev         String
  podnadpis     String
  textCast1     String
  obrazekCesta  String   // Hlavní obrázek mise
  textCast2     String?

  // Statistiky
  pocetBodu     String
  vzdalenost    String
  obtiznost     String
  cas           String
  bonusy        String
  typ           String   // Např. "Zvuková", "Historická"

  // Souřadnice pro hlavní startovní bod/cíl na mapě
  hlavniLat     Float?
  hlavniLon     Float?

  bodyMise      BodMise[]

  vytvoreno     DateTime @default(now())
  upraveno      DateTime @updatedAt
}

model BodMise {
  id              String   @id @default(cuid())
  miseId          String
  mise            Mise     @relation(fields: [miseId], references: [id], onDelete: Cascade)

  poradi          Int      // Pořadí v trase (1, 2, 3...)
  nazevBodu       String
  podnadpis       String?
  textCast1       String
  textCast2       String?

  // Galerie obrázků (uloženo jako JSON string: ["cesta1", "cesta2"])
  obrazkyGalerie  String?

  lat             Float
  lon             Float

  // Bonusový obsah
  bonusAudioPath  String?
  bonusObrazky    String?  // Galerie pro bonusy (JSON string)

  bonusoveStranky BonusovaStranka[]

  @@unique([miseId, poradi])
}

model BonusovaStranka {
  id              String   @id @default(cuid())
  bodMiseId       String
  bodMise         BodMise  @relation(fields: [bodMiseId], references: [id], onDelete: Cascade)

  poradi          Int
  obrazek         String?
  podnadpis       String?
  text            String
  malyText        String?
  zaoblitObrazek  Boolean  @default(false)
}